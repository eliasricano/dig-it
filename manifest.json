{
  "manifest_version": 3,
  "name": "Dig It!",
  "version": "1.0.0",
  "description": "The musician's tool for transcribing music on YouTube",
  "icons": {
    "128": "images/dig-it-icon-temp-128.png"
  },
  "content_scripts": [
    {
      "js": ["content.js"],
      "css": ["styles.css"],
      "matches": ["https://www.youtube.com/watch?*"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["images/*.svg"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
